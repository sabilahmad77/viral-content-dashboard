# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/viraldash

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-this-to-64-random-chars-minimum-must-be-strong
JWT_REFRESH_SECRET=change-this-to-different-64-random-chars-also-strong

# AI APIs
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
BFL_API_KEY=your-flux-bfl-key
IDEOGRAM_API_KEY=your-ideogram-key
KLING_API_KEY=your-kling-key
RUNWAY_API_KEY=your-runway-key

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=viral-dashboard-outputs
R2_PUBLIC_URL=https://your-r2-public-domain.com

# App
NEXT_PUBLIC_API_URL=http://localhost:3001
PORT=3001
NODE_ENV=development

# Initial Super Admin (for seeding)
SEED_ADMIN_EMAIL=admin@viraldash.com
SEED_ADMIN_PASSWORD=change-this-strong-password
SEED_ADMIN_NAME=Super Admin
